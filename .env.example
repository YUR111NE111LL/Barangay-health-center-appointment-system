APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=barangay_health_center_appointment_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For real-time WebSockets, set BROADCAST_CONNECTION=reverb and run: php artisan reverb:start
REVERB_APP_ID=your-app-id
REVERB_APP_KEY=your-app-key
REVERB_APP_SECRET=your-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: "log" = emails written to storage/logs only (no real send). Use "smtp" to send (e.g. Gmail).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Gmail: set MAIL_MAILER=smtp, MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls,
# MAIL_USERNAME=your@gmail.com, MAIL_PASSWORD=App Password (Google Account → Security → App passwords).
# Then run: php artisan config:clear

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Login with Google) - use a "Web application" OAuth 2.0 Client from Google Cloud Console.
# Copy Client ID and Client Secret exactly (no extra spaces or quotes). "invalid_client" = wrong credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use ONE authorized redirect URI (central app). Defaults to APP_URL + /auth/google/callback.
# Example: GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# In Google Console → Credentials → OAuth 2.0 Client → Authorized redirect URIs, add that exact URL, e.g.:
#   http://127.0.0.1:8000/auth/google/callback
# Tenant barangay hosts do not need separate redirect URIs; after Google returns here, users are sent to their tenant URL.

# Apply-for-tenant: Google allowlist (auto-provision tenant + first admin user)
# Comma-separated list of Google emails that are allowed to auto-create a tenant from /apply-for-tenant.
# BARANGAY_ADMIN_GOOGLE_EMAILS=brgy.sampleadmin@gmail.com,another.admin@gmail.com

# Apply-for-tenant: auto-provision when applicant email is @gmail.com (DANGEROUS in production)
# If true, submitting /apply-for-tenant with an @gmail.com email will create the tenant immediately,
# create that email as the first Health Center Admin, and email the staff/resident login links.
# BHCAS_AUTO_PROVISION_TENANT_FOR_GMAIL_APPLICATIONS=false

# Apply-for-tenant: auto-provision for ANY email (DANGEROUS in production)
# If true, submitting /apply-for-tenant will create the tenant immediately for any email address
# and create that email as the first Health Center Admin, then email a one-click dashboard link.
# This overrides the Gmail-only toggle when enabled.
# BHCAS_AUTO_PROVISION_TENANT_FOR_ANY_EMAIL_APPLICATIONS=false

# Login page: background. Options: teal (gradient), slate (gray), or custom (set BHCAS_LOGIN_BACKGROUND_COLOR to a hex)
# BHCAS_LOGIN_BACKGROUND=teal
# BHCAS_LOGIN_BACKGROUND_COLOR=
# BHCAS_LOGO_PATH=images/bhcs-logo.png
# BHCAS_CURRENCY_SYMBOL=₱
# Optional: base URL of the central app (landing). Defaults to APP_URL. Use when APP_URL is not the central domain.
# CENTRAL_APP_URL=http://localhost:8000
# UI timezone for date/time columns (Laravel DB times are usually UTC; this is for display).
# BHCAS_DISPLAY_TIMEZONE=Asia/Manila

# reCAPTCHA v3 (Login) - from reCAPTCHA Admin
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=
# Score 0.0–1.0; default 0.35. Raise if you get spam; lower if legitimate users fail.
# RECAPTCHA_V3_SCORE_THRESHOLD=0.35
# If verification fails behind a proxy/load balancer, try false (stops sending client IP to Google).
# RECAPTCHA_VERIFY_REMOTE_IP=true

# For announcement/event images and tenant logos to appear, run: php artisan storage:link
